local SellZone = Workspace:WaitForChild("Zones"):WaitForChild("SellZone")

local Config = {
    Goal = 1000000,
    IdleDelay = 0.12,
    BuyTimeout = 1.5,
    PlaceTimeout = 1.5,
    SellTimeout = 1.5,
    PromptPreDelay = 0.15,
    PromptPostDelay = 0.45,
    TeleportYOffset = 4,
    TeleportForwardOffset = 3,
    PlaceStep = 4.0,
    PlacePadding = 4.0,
    Costs = {
        BasicEgg = 20,
        RareEgg = 125,
        EpicEgg = 1000,
        OverloadEgg = 2000,
        LegendaryEgg = 12000,
        AstroEgg = 35000,
    },
}

local NilIdentifier = Identifiers:WaitForChild("NilIdentifier").Value
local FuncSuccessIdentifier = Identifiers:WaitForChild("NetworkFunc_Success").Value
local FuncNoFunctionIdentifier = Identifiers:WaitForChild("NetworkFunc_NoFunctionAvailble").Value
local FuncErroredIdentifier = Identifiers:WaitForChild("NetworkFunc_Errored").Value

local function log(...)
    print("[egg-bot]", ...)
end

local function warnf(...)
    warn("[egg-bot]", ...)
end

local function promptApiAvailable()
    return typeof(fireproximityprompt) == "function"
end

local function getCharacter()
    return LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
end

local function getHumanoid()
    local character = getCharacter()
    return character:FindFirstChildOfClass("Humanoid")
end

local function getRootPart()
    local character = getCharacter()
    return character:WaitForChild("HumanoidRootPart")
end

local function waitUntil(predicate, timeout)
    local deadline = os.clock() + timeout
    while os.clock() < deadline do
        if predicate() then
            return true
        end
        task.wait(0.03)
    end
    return false
end

local function stripDashesGuidToBinary()
    local guid = HttpService:GenerateGUID(false):gsub("-", "")
    return (guid:gsub("..", function(hex)
        return string.char(tonumber(hex, 16))
    end))
end

local function getIdentifier(name)
    local node = Identifiers:FindFirstChild(name)
    return node and node.Value or nil
end

local function hashActionName(actionName)
    return Framework.Hash.sha512_256(actionName)
end

local function getFunctionIdentifiers(actionName)
    local hash = hashActionName(actionName)
    local sendId = getIdentifier("RF_" .. hash .. "_S")
    local receiveId = getIdentifier("RF_" .. hash .. "_R")
    return sendId, receiveId
end

local function rawInvoke(actionName, ...)
    local sendId, receiveId = getFunctionIdentifiers(actionName)
    if not sendId or not receiveId then
        return false, "missing identifiers for " .. tostring(actionName)
    end

    local requestId = stripDashesGuidToBinary()
    local packet = { sendId, requestId }
    local argCount = select("#", ...)
    for i = 1, argCount do
        local value = select(i, ...)
        packet[#packet + 1] = value == nil and NilIdentifier or value
    end

    local done = false
    local responseStatus = nil
    local responsePack = table.pack()

    local connection
    connection = DataRemote.OnClientEvent:Connect(function(batch)
        if typeof(batch) ~= "table" then
            return
        end

        for _, incoming in pairs(batch) do
            if typeof(incoming) == "table" and incoming[1] == receiveId and incoming[2] == requestId then
                responseStatus = incoming[3]
                local n = 0
                for i = 4, #incoming do
                    n = n + 1
                    local value = incoming[i]
                    responsePack[n] = value == NilIdentifier and nil or value
                end
                responsePack.n = n
                done = true
                if connection then
                    connection:Disconnect()
                    connection = nil
                end
                return
            end
        end
    end)

    local sendOk, sendErr = pcall(function()
        DataRemote:FireServer({ packet })
    end)

    if not sendOk then
        if connection then
            connection:Disconnect()
        end
        return false, sendErr
    end

    local gotResponse = waitUntil(function()
        return done
    end, 4.0)

    if connection then
        connection:Disconnect()
    end

    if not gotResponse then
        return false, "invoke timeout for " .. tostring(actionName)
    end

    if responseStatus == FuncSuccessIdentifier then
        return true, table.unpack(responsePack, 1, responsePack.n)
    end

    if responseStatus == FuncNoFunctionIdentifier then
        return false, "server has no function for " .. tostring(actionName)
    end

    if responseStatus == FuncErroredIdentifier then
        return false, "server errored for " .. tostring(actionName)
    end

    return false, "unknown invoke response for " .. tostring(actionName)
end

local function getBalance()
    local leaderstats = LocalPlayer:FindFirstChild("leaderstats")
    if not leaderstats then
        return 0
    end

    local stat = leaderstats:FindFirstChild("Farm Tokens") or leaderstats:FindFirstChild("Money")
    return stat and stat.Value or 0
end

local function getPlayerPlot()
    local plotName = LocalPlayer:GetAttribute("PlotName")
    if not plotName then
        return nil
    end
    return Plots:FindFirstChild(plotName)
end

local function getAllTools()
    local out = {}
    local character = LocalPlayer.Character

    for _, child in ipairs(LocalPlayer.Backpack:GetChildren()) do
        if child:IsA("Tool") then
            out[#out + 1] = child
        end
    end

    if character then
        for _, child in ipairs(character:GetChildren()) do
            if child:IsA("Tool") then
                out[#out + 1] = child
            end
        end
    end

    return out
end

local function getToolsByType(itemType)
    local out = {}
    for _, tool in ipairs(getAllTools()) do
        if tool:GetAttribute("Type") == itemType then
            out[#out + 1] = tool
        end
    end
    return out
end

local function findEggToolByInternalName(internalName)
    for _, tool in ipairs(getToolsByType("Eggs")) do
        if tool:GetAttribute("Name") == internalName then
            return tool
        end
    end
    return nil
end

local function teleportToCFrame(targetCFrame)
    local root = getRootPart()
    root.CFrame = targetCFrame
    task.wait(0.08)
end

local function teleportNearPart(part)
    local target = part.CFrame * CFrame.new(0, Config.TeleportYOffset, Config.TeleportForwardOffset)
    teleportToCFrame(target)
end

local function teleportToPlot()
    local plot = getPlayerPlot()
    if not plot then
        return false
    end

    local topY = plot.Position.Y + (plot.Size.Y / 2) + Config.TeleportYOffset
    teleportToCFrame(CFrame.new(plot.Position.X, topY, plot.Position.Z))
    return true
end

local function teleportToConveyor()
    teleportNearPart(ConveyorPart)
end

local function teleportToSellZone()
    teleportNearPart(SellZone)
end

local function equipTool(tool)
    local character = getCharacter()
    if tool.Parent == character then
        return true
    end

    local humanoid = getHumanoid()
    if not humanoid then
        return false
    end

    humanoid:EquipTool(tool)
    return waitUntil(function()
        return tool.Parent == character
    end, 1.0)
end

local function countOwnedPlacedEggs()
    local count = 0
    for _, item in ipairs(PlacedItems:GetChildren()) do
        if item:GetAttribute("OwnerId") == LocalPlayer.UserId and item:GetAttribute("Type") == "Eggs" then
            count = count + 1
        end
    end
    return count
end

local function buildGhostModel(internalEggName)
    local template = EggModels:FindFirstChild(internalEggName)
    if not template then
        return nil
    end

    local ghost = template:Clone()
    ghost.Parent = DebrisFolder

    for _, descendant in ipairs(ghost:GetDescendants()) do
        if descendant:IsA("BasePart") then
            descendant.CanCollide = false
            descendant.CanTouch = false
            descendant.CanQuery = false
        end
    end

    return ghost
end

local function isCandidateInsidePlot(candidateCFrame, plot)
    return Utility.IsPointInPart(candidateCFrame.Position + Vector3.new(0, -0.01, 0), plot)
end

local function isCandidateClear(candidateCFrame, internalEggName)
    local ghost = buildGhostModel(internalEggName)
    if not ghost then
        return false
    end

    ghost:PivotTo(candidateCFrame)
    local boundsCFrame, boundsSize = ghost:GetBoundingBox()
    ghost:Destroy()

    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Include
    params.FilterDescendantsInstances = { PlacedItems }

    local origin = boundsCFrame.Position
    local hit = Workspace:Raycast(origin, boundsCFrame.RightVector * (boundsSize.X / 3), params)
        or Workspace:Raycast(origin, -boundsCFrame.RightVector * (boundsSize.X / 3), params)
        or Workspace:Raycast(origin, boundsCFrame.LookVector * (boundsSize.Z / 3), params)
        or Workspace:Raycast(origin, -boundsCFrame.LookVector * (boundsSize.Z / 3), params)

    return hit == nil
end

local function iteratePlacementCFrames(plot)
    local candidates = {}
    local _, yaw, _ = plot.CFrame:ToOrientation()
    local topY = plot.Position.Y + (plot.Size.Y / 2)

    local minX = -plot.Size.X / 2 + Config.PlacePadding
    local maxX = plot.Size.X / 2 - Config.PlacePadding
    local minZ = -plot.Size.Z / 2 + Config.PlacePadding
    local maxZ = plot.Size.Z / 2 - Config.PlacePadding

    for x = minX, maxX, Config.PlaceStep do
        for z = minZ, maxZ, Config.PlaceStep do
            local worldPosition = (plot.CFrame * CFrame.new(x, 0, z)).Position
            candidates[#candidates + 1] = CFrame.new(worldPosition.X, topY, worldPosition.Z) * CFrame.Angles(0, yaw, 0)
        end
    end

    return candidates
end

local function findNextValidPlacementCFrame(tool)
    local plot = getPlayerPlot()
    if not plot then
        return nil
    end

    local internalEggName = tool:GetAttribute("Name")
    if not internalEggName then
        return nil
    end

    for _, candidate in ipairs(iteratePlacementCFrames(plot)) do
        if isCandidateInsidePlot(candidate, plot) and isCandidateClear(candidate, internalEggName) then
            return candidate
        end
    end

    return nil
end

local function getConveyorEggs()
    local ok, eggsOrErr = rawInvoke("EggConveyor_GetEggs")
    if not ok or type(eggsOrErr) ~= "table" then
        return {}
    end
    return eggsOrErr
end

local function conveyorStillHasUID(uid)
    for _, egg in ipairs(getConveyorEggs()) do
        if egg.uid == uid then
            return true
        end
    end
    return false
end

local function chooseTargetEgg(balance, eggs)
    local priority

    if balance < Config.Costs.RareEgg then
        priority = { "BasicEgg" }
    elseif balance < Config.Costs.OverloadEgg then
        priority = { "RareEgg", "BasicEgg" }
    elseif balance < Config.Costs.LegendaryEgg then
        priority = { "OverloadEgg", "RareEgg" }
    elseif balance < Config.Costs.AstroEgg then
        priority = { "LegendaryEgg", "OverloadEgg" }
    else
        priority = { "AstroEgg", "LegendaryEgg" }
    end

    for _, targetId in ipairs(priority) do
        for _, egg in ipairs(eggs) do
            local cost = Config.Costs[egg.id]
            if egg.id == targetId and cost and balance >= cost then
                return egg
            end
        end
    end

    return nil
end

local function findConveyorPromptForEggId(eggId)
    local itemConfig = Framework.Inventory.GetItemConfig("Eggs", eggId)
    if not itemConfig then
        return nil
    end

    local conveyorEggs = Workspace:FindFirstChild("ConveyorEggs")
    if not conveyorEggs then
        return nil
    end

    for _, descendant in ipairs(conveyorEggs:GetDescendants()) do
        if descendant:IsA("ProximityPrompt") and descendant.Enabled and descendant.ActionText == itemConfig.DisplayName then
            return descendant
        end
    end

    return nil
end

local function triggerPrompt(prompt)
    if not promptApiAvailable() then
        return false
    end

    local base = prompt.Parent
    local targetCFrame

    if base and base:IsA("BasePart") then
        targetCFrame = base.CFrame * CFrame.new(0, Config.TeleportYOffset, Config.TeleportForwardOffset)
    elseif base and base:IsA("Model") then
        targetCFrame = base:GetPivot() * CFrame.new(0, Config.TeleportYOffset, Config.TeleportForwardOffset)
    else
        return false
    end

    teleportToCFrame(targetCFrame)
    task.wait(Config.PromptPreDelay)
    fireproximityprompt(prompt)
    task.wait(Config.PromptPostDelay)
    return true
end

local function buyEggByUID(conveyorEgg)
    teleportToConveyor()

    local balanceBefore = getBalance()
    local hadToolBefore = findEggToolByInternalName(conveyorEgg.id) ~= nil
    log("Buying egg:", conveyorEgg.id, conveyorEgg.uid)

    local ok, err = rawInvoke("EggConveyor_BuyEgg", conveyorEgg.uid)
    if not ok then
        warnf("Raw buy failed, trying prompt fallback:", err)

        local prompt = findConveyorPromptForEggId(conveyorEgg.id)
        if not prompt or not triggerPrompt(prompt) then
            return false, err or "buy failed and no prompt fallback"
        end
    end

    local confirmed = waitUntil(function()
        if getBalance() < balanceBefore then
            return true
        end
        if not conveyorStillHasUID(conveyorEgg.uid) then
            return true
        end
        if not hadToolBefore and findEggToolByInternalName(conveyorEgg.id) then
            return true
        end
        return false
    end, Config.BuyTimeout)

    if not confirmed then
        return false, "buy had no visible confirmation"
    end

    return true
end

local function placeEggAt(targetCFrame)
    return rawInvoke("PlaceObjectRequest", targetCFrame)
end

local function placeToolStack(tool)
    local plantedAnything = false

    teleportToPlot()

    while tool and tool.Parent do
        if not equipTool(tool) then
            return plantedAnything, "failed to equip egg tool"
        end

        local targetCFrame = findNextValidPlacementCFrame(tool)
        if not targetCFrame then
            return plantedAnything, "no valid placement point found"
        end

        local beforeCount = countOwnedPlacedEggs()
        local ok, err = placeEggAt(targetCFrame)
        if not ok then
            return plantedAnything, err or "place invoke failed"
        end

        local placed = waitUntil(function()
            return countOwnedPlacedEggs() > beforeCount or tool.Parent == nil
        end, Config.PlaceTimeout)

        if not placed then
            return plantedAnything, "placement had no visible world change"
        end

        plantedAnything = true
        task.wait(0.05)
    end

    return plantedAnything
end

local function placeAllOwnedEggTools()
    local progressed = false

    while true do
        local tools = getToolsByType("Eggs")
        if #tools == 0 then
            break
        end

        local planted, err = placeToolStack(tools[1])
        if not planted then
            if err then
                warnf("place stack stopped:", err)
            end
            break
        end

        progressed = true
    end

    return progressed
end

local function findPromptRecursive(root, actionText)
    for _, descendant in ipairs(root:GetDescendants()) do
        if descendant:IsA("ProximityPrompt") and descendant.Enabled and descendant.ActionText == actionText then
            return descendant
        end
    end
    return nil
end

local function hatchAllReady()
    if not promptApiAvailable() then
        return false
    end

    local progressed = false
    teleportToPlot()

    for _, item in ipairs(PlacedItems:GetChildren()) do
        if item:GetAttribute("OwnerId") == LocalPlayer.UserId and item:GetAttribute("Type") == "Eggs" then
            local timeLeft = item:GetAttribute("TimeLeft")
            if timeLeft ~= nil and timeLeft <= 0 then
                local prompt = findPromptRecursive(item, "Hatch!")
                if prompt then
                    log("Hatching:", item.Name)
                    triggerPrompt(prompt)
                    progressed = true
                end
            end
        end
    end

    return progressed
end

local function pickUpAll()
    if not promptApiAvailable() then
        return false
    end

    local humanoid = getHumanoid()
    if humanoid then
        humanoid:UnequipTools()
    end

    local progressed = false
    teleportToPlot()

    for _, prompt in ipairs(CollectionService:GetTagged("PickUpToiletPrompt")) do
        if prompt:IsA("ProximityPrompt") and prompt.Enabled then
            local ownerModel = prompt:FindFirstAncestorOfClass("Model")
            if ownerModel and ownerModel:GetAttribute("OwnerId") == LocalPlayer.UserId then
                log("Picking up:", ownerModel.Name)
                triggerPrompt(prompt)
                progressed = true
            end
        end
    end

    return progressed
end

local function sellEverything()
    local toiletTools = getToolsByType("Toilets")
    if #toiletTools == 0 then
        return false
    end

    teleportToSellZone()
    log("Selling all toilets:", #toiletTools)

    local balanceBefore = getBalance()
    local ok, err = rawInvoke("SellAllItems")
    if not ok then
        warnf("sell failed:", err)
        return false
    end

    local sold = waitUntil(function()
        return #getToolsByType("Toilets") < #toiletTools or getBalance() > balanceBefore
    end, Config.SellTimeout)

    teleportToPlot()
    return sold
end

local function buyBatch()
    if #getToolsByType("Eggs") > 0 then
        return false
    end

    local progressed = false
    teleportToConveyor()

    while true do
        local balance = getBalance()
        local eggs = getConveyorEggs()
        local target = chooseTargetEgg(balance, eggs)

        if not target then
            break
        end

        local bought, err = buyEggByUID(target)
        if not bought then
            warnf("buy failed:", err)
            break
        end

        progressed = true
    end

    return progressed
end

local function runActionPump()
    local didSomething = false

    if placeAllOwnedEggTools() then
        didSomething = true
    end

    if hatchAllReady() then
        didSomething = true
    end

    if pickUpAll() then
        didSomething = true
    end

    if sellEverything() then
        didSomething = true
    end

    if buyBatch() then
        didSomething = true
        if placeAllOwnedEggTools() then
            didSomething = true
        end
    end

    return didSomething
end

task.spawn(function()
    while true do
        local ok, err = pcall(function()
            if getBalance() >= Config.Goal then
                log("Goal reached:", getBalance())
                task.wait(5)
                return
            end

            local progressed = runActionPump()
            if not progressed then
                task.wait(Config.IdleDelay)
            end
        end)

        if not ok then
            warnf("main loop error:", err)
            task.wait(0.25)
        end
    end
end)
